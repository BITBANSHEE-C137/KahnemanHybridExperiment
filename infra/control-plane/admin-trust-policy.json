{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowOperatorElevation",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::004507070771:role/LabOperatorRole"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "ml-lab-elevation"
        }
      }
    }
  ]
}
