[Unit]
Description=rclone iCloud Drive FUSE mount
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
User=claude-operator
ExecStart=/usr/bin/rclone mount icloud: /home/claude-operator/icloud --vfs-cache-mode writes --read-only --allow-other --config /home/claude-operator/.config/rclone/rclone.conf
ExecStop=/bin/fusermount -u /home/claude-operator/icloud
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
