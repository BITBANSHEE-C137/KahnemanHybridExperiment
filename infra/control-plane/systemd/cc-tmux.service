[Unit]
Description=Claude Code tmux session
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=claude-operator
ExecStart=/usr/bin/tmux new-session -d -s cc-control -n claude-code \; \
  new-window -t cc-control -n monitor \; \
  new-window -t cc-control -n ssh \; \
  select-window -t cc-control:claude-code
ExecStop=/usr/bin/tmux kill-session -t cc-control

[Install]
WantedBy=multi-user.target
